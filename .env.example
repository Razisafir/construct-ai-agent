# ============================================================================
# Construct AI Agent — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values as needed.
# All paths are relative to the project root unless otherwise noted.
# ============================================================================

# --- SQLite Database ---
# Relational store for raw messages, code events, and structured data.
DB_PATH=./resources/memory/construct.db

# --- ChromaDB Vector Storage ---
# Persistent directory where ChromaDB keeps its SQLite + vector index files.
CHROMA_PATH=./resources/memory/vector

# --- Embedding Model ---
# Sentence-transformers model name.  "all-MiniLM-L6-v2" is the default:
#   - 384-dim embeddings
#   - ~80 MB download
#   - fast inference on CPU
# Alternatives: "all-mpnet-base-v2" (better quality, slower), "multi-qa-MiniLM-L6-cos-v1"
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Python Memory API Server ---
MEMORY_API_HOST=127.0.0.1
MEMORY_API_PORT=8000

# --- Tauri Frontend Dev URL (for CORS) ---
TAURI_DEV_URL=http://localhost:5173

# ============================================================================
# LLM Providers (at least one required for agent to function)
# ============================================================================

# --- OpenAI ---
# Get API key: https://platform.openai.com/api-keys
# PLACEHOLDER: Replace with your actual API key (starts with sk-)
OPENAI_API_KEY=sk-placeholder-replace-me
OPENAI_MODEL=gpt-4o

# --- Anthropic (recommended for coding) ---
# Get API key: https://console.anthropic.com/settings/keys
# PLACEHOLDER: Replace with your actual API key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini ---
# Get API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-1.5-pro

# --- Ollama (local, free, no API key needed) ---
# Install: https://ollama.com/download
# Pull model: ollama pull qwen2.5-coder:14b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# ============================================================================
# Agent Settings
# ============================================================================

# Default LLM provider when "auto" routing is used
# Options: openai, anthropic, google, ollama
DEFAULT_LLM_PROVIDER=ollama

# Max tool calls per task before stopping
MAX_TOOL_CALLS_PER_TASK=10

# Require human approval before executing destructive operations
# Options: always, destructive_only, never
REQUIRE_APPROVAL=destructive_only

# Paths that require approval to modify (comma-separated)
PROTECTED_PATHS=.env,*.key,*.pem,node_modules/,target/

# ============================================================================
# Agent Safety
# ============================================================================

# Require approval for these tool categories
# Options: all, destructive, none
SAFETY_LEVEL=destructive

# Allowed shell commands (comma-separated, * = all allowed)
# If empty, only safe commands are allowed
ALLOWED_COMMANDS=npm,npx,cargo,python,python3,git,eslint,prettier,tsc,vitest
